<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.AAPS.Dashboard.Card" parent="@style/Widget.MaterialComponents.CardView">
        <item name="cardElevation">@dimen/dashboard_card_elevation</item>
        <!-- false: less outer gap vs compat shadow padding (dashboard felt overly spaced on phones). -->
        <item name="cardUseCompatPadding">false</item>
        <item name="cardBackgroundColor">@color/dashboard_card_background</item>
        <item name="strokeColor">@color/dashboard_card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/dashboard_ripple</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.AAPS.Dashboard.Card</item>
    </style>

    <style name="ShapeAppearance.AAPS.Dashboard.Card" parent="@style/ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/dashboard_card_corner_large</item>
        <item name="cornerSizeTopRight">@dimen/dashboard_card_corner_large</item>
        <item name="cornerSizeBottomRight">@dimen/dashboard_card_corner_large</item>
        <item name="cornerSizeBottomLeft">@dimen/dashboard_card_corner_small</item>
    </style>

    <style name="TextAppearance.AAPS.Dashboard.SectionTitle" parent="@style/TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/dashboard_on_surface</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.AAPS.Dashboard.PrimaryLine" parent="@style/TextAppearance.MaterialComponents.Body2">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/dashboard_on_surface</item>
    </style>

    <style name="TextAppearance.AAPS.Dashboard.SecondaryLine" parent="@style/TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/dashboard_on_surface</item>
    </style>

    <style name="TextAppearance.AAPS.Dashboard.MetricValue" parent="@style/TextAppearance.MaterialComponents.Caption">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/dashboard_on_surface</item>
    </style>

    <style name="TextAppearance.AAPS.Dashboard.MetaLabel" parent="@style/TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/dashboard_on_surface_muted</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="Widget.AAPS.Dashboard.RunLoopButton" parent="@style/Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/dashboard_on_surface</item>
        <item name="strokeColor">@color/dashboard_on_surface</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.AAPS.Dashboard.ActionChip" parent="@style/Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">@color/dashboard_chip_bg_selector</item>
        <item name="chipStrokeColor">@color/dashboard_chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/dashboard_chip_text_selector</item>
        <item name="chipCornerRadius">14dp</item>
        <item name="chipMinHeight">32dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="rippleColor">@color/dashboard_ripple</item>
        <item name="closeIconVisible">false</item>
        <item name="android:checkable">true</item>
        <item name="checkedIconVisible">false</item>
    </style>

</resources>
