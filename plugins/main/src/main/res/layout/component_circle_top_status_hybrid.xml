<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:padding="@dimen/dashboard_card_inner_padding">

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TOP SECTION: Circle + Badges + Trend               -->
        <!-- ═══════════════════════════════════════════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:paddingBottom="4dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:minHeight="@dimen/dashboard_glucose_hero_min_side">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/dashboard_hero_split_guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.42" />

            <!-- Glucose hero (Compose): left column, square; frees space for status stack on the right -->
            <FrameLayout
                android:id="@+id/glucose_ring_container"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="@dimen/dashboard_hero_ring_margin_end"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:elevation="6dp"
                app:layout_constraintWidth_max="@dimen/dashboard_glucose_hero_width_max"
                app:layout_constraintWidth_min="@dimen/dashboard_glucose_hero_min_side"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/dashboard_hero_split_guideline"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.compose.ui.platform.ComposeView
                    android:id="@+id/glucose_hero_compose"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <!-- Context Badge (on ring) -->
            <ImageView
                android:id="@+id/aimi_context_indicator"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/aimi_context"
                android:elevation="20dp"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_graduation"
                app:tint="?android:attr/textColorPrimary"
                app:layout_constraintTop_toTopOf="@id/glucose_ring_container"
                app:layout_constraintStart_toStartOf="@id/glucose_ring_container"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp" />

            <!-- Auditor Badge (on ring) -->
            <FrameLayout
                android:id="@+id/aimi_auditor_indicator_container"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:elevation="20dp"
                app:layout_constraintTop_toTopOf="@id/glucose_ring_container"
                app:layout_constraintEnd_toEndOf="@id/glucose_ring_container"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="8dp" />

            <!-- Right column: loop + IOB + reading / sensor (overview-style density) -->
            <LinearLayout
                android:id="@+id/dashboard_hero_status_column"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="@dimen/dashboard_hero_status_column_margin_start"
                android:gravity="center_vertical"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="@id/dashboard_hero_split_guideline"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- MaterialButton (style chip) : évite crash d’inflation / thème fréquent avec Chip dans un <merge> custom view. -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loop_status_chip"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="40dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/closed_loop"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/dashboard_on_surface"
                    android:maxLines="2"
                    android:ellipsize="end"
                    app:cornerRadius="18dp"
                    app:backgroundTint="@color/dashboard_chip_background"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/dashboard_card_stroke"
                    app:icon="@drawable/dashboard_loop_chip_dot"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconSize="14dp"
                    app:iconTint="@color/dashboard_metric_info"
                    tools:text="Boucle fermée" />

                <TextView
                    android:id="@+id/dashboard_hero_status_iob"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dashboard_row_spacing_small"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine"
                    android:textColor="@color/dashboard_on_surface"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="IOB: 1,32 IE" />

                <TextView
                    android:id="@+id/dashboard_hero_status_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                    android:textColor="@color/dashboard_on_surface_muted"
                    android:textSize="11sp"
                    android:alpha="0.85"
                    android:lineSpacingMultiplier="1.12"
                    android:maxLines="4"
                    android:ellipsize="end"
                    tools:text="Lecture · Il y a 3 min\nCapteur · 8d 5h" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Metrics display mode + compact row / extended grid -->
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LinearLayout à la place de MaterialButtonToggleGroup : évite crash d’inflation
             (ChipGroup.LayoutParams / layout_width) observé avec certaines combinaisons SDK + Material 1.13. -->
        <LinearLayout
            android:id="@+id/dashboard_metrics_mode_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="@dimen/dashboard_row_spacing_small"
            android:elevation="2dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dashboard_metrics_simple"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:checkable="true"
                android:text="@string/dashboard_metrics_mode_simple"
                android:textSize="12sp"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dashboard_metrics_extended"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="40dp"
                android:checkable="true"
                android:text="@string/dashboard_metrics_mode_extended"
                android:textSize="12sp"
                app:cornerRadius="14dp" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/dashboard_metrics_compact_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/dashboard_compact_metric_min_width"
                    android:orientation="vertical"
                    android:paddingEnd="@dimen/dashboard_chip_spacing"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_compact_label_steps"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" />

                    <TextView
                        android:id="@+id/dashboard_compact_steps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/dashboard_compact_metric_min_width"
                    android:orientation="vertical"
                    android:paddingEnd="@dimen/dashboard_chip_spacing"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_compact_label_iob"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" />

                    <TextView
                        android:id="@+id/dashboard_compact_iob"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/dashboard_compact_metric_min_width"
                    android:orientation="vertical"
                    android:paddingEnd="@dimen/dashboard_chip_spacing"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_compact_label_hr"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" />

                    <TextView
                        android:id="@+id/dashboard_compact_hr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/dashboard_compact_metric_min_width"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_compact_label_tbr"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" />

                    <TextView
                        android:id="@+id/dashboard_compact_basal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- METRICS ROW: Left Column + Right Column (Étendu)   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/dashboard_metrics_extended_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="@dimen/dashboard_row_spacing_small">

            <!-- LEFT COLUMN -->
            <LinearLayout
                android:id="@+id/left_col"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/dashboard_extended_section_left_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/dashboard_extended_section_left"
                    android:textAllCaps="true"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                    android:letterSpacing="0.06" />

                <!-- STEPS (First Item) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_dashboard_shoe"
                        app:tint="@color/dashboard_on_surface_muted" />

                    <TextView
                        android:id="@+id/steps_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/dashboard_on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Reservoir -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_cp_age_insulin"
                        app:tint="@color/dashboard_on_surface" />

                    <TextView
                        android:id="@+id/reservoir_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="@color/dashboard_on_surface" />
                </LinearLayout>

                <!-- COB (Carbs On Board) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_cp_bolus_carbs"
                        app:tint="@color/dashboard_metric_attention" />

                    <TextView
                        android:id="@+id/cob_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetricValue"
                        android:textColor="@color/dashboard_metric_attention" />
                </LinearLayout>

                <!-- CV (Coefficient of Variation) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_dashboard_wave"
                        app:tint="@color/dashboard_on_surface" />

                    <TextView
                        android:id="@+id/cv_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CV --%"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="@color/dashboard_on_surface" />
                </LinearLayout>
                
                <!-- Pump Battery -->
                <LinearLayout
                    android:id="@+id/pump_battery_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_cp_age_battery"
                        app:tint="@color/dashboard_on_surface" />

                    <TextView
                        android:id="@+id/pump_battery_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="@color/dashboard_on_surface" />
                </LinearLayout>
            </LinearLayout>

            <!-- RIGHT COLUMN -->
            <LinearLayout
                android:id="@+id/right_col"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/dashboard_extended_section_right_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:gravity="end"
                    android:text="@string/dashboard_extended_section_right"
                    android:textAllCaps="true"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                    android:letterSpacing="0.06" />

                <!-- HEART RATE (First Item) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_cp_heart_rate"
                        app:tint="@color/dashboard_on_surface_muted" />

                    <TextView
                        android:id="@+id/hr_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/dashboard_on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Last Update (or IOB actually mapped here in previous code) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_dashboard_droplet"
                        app:tint="@color/dashboard_metric_info" />

                    <TextView
                        android:id="@+id/last_sensor_value_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetricValue"
                        android:textColor="@color/dashboard_metric_info" />

                    <FrameLayout
                        android:id="@+id/adaptive_smoothing_quality_badge"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="6dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/dashboard_chip_background_quality_ok"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone"
                        android:contentDescription="@string/adaptive_smoothing_quality_badge_a11y">

                        <ImageView
                            android:id="@+id/adaptive_smoothing_quality_icon"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            app:srcCompat="@drawable/ic_dashboard_wave"
                            app:tint="@color/dashboard_on_surface_muted" />
                    </FrameLayout>
                </LinearLayout>

                <!-- TBR Rate & % -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_sensor_reading"
                        app:tint="@color/dashboard_metric_warning" />

                    <TextView
                        android:id="@+id/tbr_rate_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 U/h"
                        android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetricValue"
                        android:textColor="@color/dashboard_metric_warning" />
                </LinearLayout>

                <!-- Basal Profile -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_cp_basal"
                        app:tint="@color/dashboard_on_surface" />

                    <TextView
                        android:id="@+id/basal_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="@color/dashboard_on_surface" />
                </LinearLayout>

                <!-- Activity % (Relative to Basal) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="3dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"
                        app:srcCompat="@drawable/ic_cp_basal"
                        app:tint="@color/dashboard_on_surface" />

                    <TextView
                        android:id="@+id/activity_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                        android:textColor="@color/dashboard_on_surface" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- AIMI PULSE — last APS reason + facts (tap → details) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/aimi_pulse_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/dashboard_section_spacing"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/dashboard_chip_background"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:id="@+id/aimi_pulse_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.SectionTitle"
                android:textSize="12sp"
                android:text="@string/dashboard_aimi_pulse_title" />

            <TextView
                android:id="@+id/aimi_pulse_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.02"
                android:maxLines="4"
                android:ellipsize="end"
                tools:text="OpenAPS reason excerpt…" />

            <TextView
                android:id="@+id/aimi_pulse_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                android:textColor="@color/dashboard_on_surface_muted"
                tools:text="SMB 0.1 U · basal 0.9 U/h · AutoSens 100%" />

            <TextView
                android:id="@+id/aimi_pulse_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/dashboard_aimi_pulse_hint"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                android:textSize="9sp"
                android:alpha="0.75" />
        </LinearLayout>

        <TextView
            android:id="@+id/aimi_telemetry_section_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_row_spacing_small"
            android:text="@string/dashboard_aimi_telemetry_label"
            android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
            android:textAllCaps="true"
            android:letterSpacing="0.08" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- AIMI INSIGHTS (T3c, Manoeuvre, AI Factor)           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/aimi_insights_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="@dimen/dashboard_row_spacing_small"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/dashboard_chip_background"
            android:alpha="0.92">

            <!-- T3c (Time to Control) -->
            <TextView
                android:id="@+id/insight_t3c"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯 --"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                android:textColor="@color/dashboard_on_surface"
                android:layout_marginEnd="8dp" />

            <!-- Manoeuvre (Trajectory Type) -->
            <TextView
                android:id="@+id/insight_manoeuvre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌀 --"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                android:textColor="@color/dashboard_on_surface"
                android:layout_marginEnd="8dp" />

            <!-- Cosinus Factor (IA Attention) -->
            <TextView
                android:id="@+id/insight_factor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ x1.0"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                android:textColor="@color/dashboard_on_surface" />

        </LinearLayout>

        <!-- AIMI ML / telemetry confidence (sensor + relevance + health) -->
        <LinearLayout
            android:id="@+id/aimi_ml_confidence_strip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="@dimen/dashboard_row_spacing_small"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/dashboard_chip_background">

            <TextView
                android:id="@+id/aimi_ml_confidence_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_aimi_ml_confidence_title"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textColor="@color/dashboard_on_surface_muted" />

            <TextView
                android:id="@+id/aimi_ml_confidence_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.AAPS.Dashboard.PrimaryLine"
                android:textSize="12sp"
                android:textColor="@color/dashboard_on_surface"
                android:lineSpacingMultiplier="1.02"
                tools:text="Sensor OK · Relevance 87% · Health 72%" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TIR BAR (24H) — inset card                           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dashboard_tir_horizontal_inset"
            android:layout_marginEnd="@dimen/dashboard_tir_horizontal_inset"
            android:layout_marginTop="@dimen/dashboard_section_spacing"
            android:layout_marginBottom="6dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dashboard_card_stroke"
            app:cardBackgroundColor="@color/dashboard_card_background"
            app:contentPadding="@dimen/dashboard_row_spacing_medium">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="2dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dashboard_tir_today"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textColor="@color/dashboard_on_surface_muted" />
                <TextView
                    android:id="@+id/tir_stats_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_tir_stats_placeholder"
                    android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel"
                    android:textColor="@color/dashboard_on_surface" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:orientation="horizontal"
                android:background="@color/dashboard_tir_track">
                <View
                    android:id="@+id/tir_very_low_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.01"
                    android:background="@color/dashboard_tir_very_low" />
                <View
                    android:id="@+id/tir_low_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.04"
                    android:background="@color/dashboard_tir_low" />
                <View
                    android:id="@+id/tir_in_range_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.75"
                    android:background="@color/dashboard_tir_in_range" />
                <View
                    android:id="@+id/tir_high_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.15"
                    android:background="@color/dashboard_tir_high" />
                <View
                    android:id="@+id/tir_very_high_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.05"
                    android:background="@color/dashboard_tir_very_low" />
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp"
                android:baselineAligned="false">
                <!-- Percentage Labels -->
                <TextView android:id="@+id/tir_very_low_label" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.05" android:text="" android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" android:textColor="@color/dashboard_tir_very_low" android:gravity="start"/>
                <TextView android:id="@+id/tir_low_label" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.2" android:text="" android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" android:textColor="@color/dashboard_tir_low" android:gravity="start"/>
                <TextView android:id="@+id/tir_in_range_label" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.5" android:text="" android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" android:textColor="@color/dashboard_tir_in_range" android:gravity="center"/>
                <TextView android:id="@+id/tir_high_label" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.2" android:text="" android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" android:textColor="@color/dashboard_tir_high" android:gravity="end"/>
                <TextView android:id="@+id/tir_very_high_label" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.05" android:text="" android:textAppearance="@style/TextAppearance.AAPS.Dashboard.MetaLabel" android:textColor="@color/dashboard_tir_very_low" android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- BOTTOM ROW: quick actions (Compose, même 4 entrées) -->
        <!-- ═══════════════════════════════════════════════════ -->
        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/dashboard_quick_actions_compose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dashboard_row_spacing_small" />
    </LinearLayout>
</merge>
